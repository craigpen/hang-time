{
  "manifest_version": 3,
  "name": "Hang Time",
  "description": "Hang out and consume content together with friends",
  "version": "0.1.0",
  "author": "Craig",
  "permissions": [
    "tabs",
    "storage",
    "webRequest",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "https://api.spotify.com/*",
    "https://api.twitch.tv/*",
    "https://api.steampowered.com/*",
    "https://accounts.spotify.com/*",
    "https://id.twitch.tv/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["oauth-handler.html"],
      "matches": ["https://accounts.spotify.com/*", "https://id.twitch.tv/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Hang Time"
  },
  "options_page": "settings.html",
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://youtu.be/*", "https://www.netflix.com/*"],
      "js": ["video-sync.js"],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src wss: https:; img-src 'self' https:; font-src 'self'"
  }
}
